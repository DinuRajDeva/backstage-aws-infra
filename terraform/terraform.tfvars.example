aws_region   = "ap-south-1"
project_name = "backstage"

ecr_image_uri = "123456789012.dkr.ecr.ap-south-1.amazonaws.com/your-repo:tag"

# Existing VPC in Mumbai — private subnets across >= 2 AZs for RDS
vpc_id = "vpc-xxxxxxxx"
rds_subnet_ids = [
  "subnet-aaaaaaa1",
  "subnet-aaaaaaa2",
]

# Allow Postgres from your app (recommended once you have an ECS task SG):
# rds_allowed_security_group_ids = ["sg-ecs-tasks"]
#
# And/or temporary admin access (replace with your IP or remove in production):
# rds_allowed_cidr_blocks = ["203.0.113.10/32"]

rds_master_password = "change-me-use-long-random-secret"

# Optional overrides
# rds_db_name = "app"
# rds_engine_version = "16"
# rds_instance_class = "db.t4g.micro"

default_tags = {
  Environment = "dev"
  Project     = "backstage"
}
